@app.get("/api/health")
async def health():
    """Health check."""
    supabase_ok = False
    if db:
        try:
            db.table("domains").select("domain").limit(1).execute()
            supabase_ok = True
        except Exception:
            pass

    return {
        "status": "ok",
        "supabase": "connected" if supabase_ok else "disconnected",
        "timestamp": datetime.utcnow().isoformat(),
        "active_agents": sum(
            1 for p in _agent_processes.values() if p.poll() is None
        ),
    }


@app.get("/api/stats")
async def get_stats():
    """Get system-wide statistics."""
    stats = {
        "shops": 0,
        "total_prices": 0,
        "total_domains": 0,
        "active_keywords": 0,
    }
    if not db:
        return stats
    try:
        shops = db.table("shops").select("*", count="exact").execute()
        stats["shops"] = shops.count or 0
    except Exception:
        pass
    try:
        prices = db.table("competitor_prices").select("*", count="exact").execute()
        stats["total_prices"] = prices.count or 0
    except Exception:
        pass
    try:
        domains = db.table("domains").select("*", count="exact").execute()
        stats["total_domains"] = domains.count or 0
    except Exception:
        pass
    try:
        kw = db.table("keyword_pool") \
            .select("*", count="exact") \
            .eq("is_active", True) \
            .execute()
        stats["active_keywords"] = kw.count or 0
    except Exception:
        pass
    return stats


